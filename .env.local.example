# ─── Supabase ──────────────────────────────────────────────────────────────────
# URL publique du projet Supabase
SUPABASE_URL=https://XXXXXXXXXXXXXXXX.supabase.co

# Clé service role — NE JAMAIS exposer côté client
SUPABASE_SERVICE_ROLE_KEY=your-supabase-service-role-key

# ─── Stripe ────────────────────────────────────────────────────────────────────
# Clé secrète Stripe (mode test : sk_test_... / prod : sk_live_...)
STRIPE_SECRET_KEY=sk_test_...

# Secret webhook Stripe (généré dans le dashboard Stripe > Webhooks)
STRIPE_WEBHOOK_SECRET=whsec_...

# ─── Email — Resend ────────────────────────────────────────────────────────────
# Clé API Resend (https://resend.com/api-keys)
RESEND_API_KEY=re_...

# Adresse d'expédition (domaine vérifié dans Resend)
FROM_EMAIL=noreply@auditloi25.ca

# Adresse de notification interne (reçoit les leads et paiements)
NOTIFY_EMAIL=votreboosterdigital@outlook.com

# ─── Webhook Zapier / CRM ──────────────────────────────────────────────────────
# URL webhook Zapier pour les nouveaux leads (optionnel)
LEAD_WEBHOOK_URL=https://hooks.zapier.com/hooks/catch/XXXXXXXX/XXXXXXXX/

# ─── Google Ads (public — préfixe NEXT_PUBLIC_) ────────────────────────────────
# ID Google Ads (format AW-XXXXXXXXXX)
NEXT_PUBLIC_GADS_ID=AW-XXXXXXXXX

# Identifiant de conversion — clic sur bouton CTA
NEXT_PUBLIC_GADS_CONVERSION_CLICK=XXXXXXXXX/XXXXXXXXXXXXXXXXXX

# Identifiant de conversion — soumission formulaire lead
NEXT_PUBLIC_GADS_CONVERSION_SUBMIT=XXXXXXXXX/XXXXXXXXXXXXXXXXXX

# ─── Site ──────────────────────────────────────────────────────────────────────
# URL publique du site (sans slash final)
NEXT_PUBLIC_SITE_URL=https://auditloi25.ca
